# Example environment for PostgreSQL (recommended)
# Set DATABASE_URL for a single connection string (Postgres)
# Example: postgres://user:password@localhost:5432/tea_db

# DATABASE_URL=postgres://user:password@localhost:5432/tea_db

# Or set MySQL variables (fallback) if using MySQL
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=secret
# DB_NAME=tea_db

# Server port
# PORT=3000
